{
	"name": "greenpeace/planet4-test-titan",
	"description": "Greenpeace P4 test-titan",
	"license": "MIT",
	"require": {
		"greenpeace/planet4-master-theme": "7",
		"wpackagist-plugin/query-monitor": "3.*",
		"guzzlehttp/psr7": "2.10.1"
	},
	"data_from": "international",
	"repositories": [
